{"changes": [{"date_iso": "2026-07-18", "date_label": "Sat.18.07.26", "description": {"new": "Born out of community driven events in studios and shaped by a strong sense of scene identity, a small group of like minded individuals formed around recaved.collective, united by a shared passion for electronic music. While remaining open to other genres, Recaved dedicates this night entirely to the more serious facets of the sound. No trends, just pure techno.\n\nAdmission 20 € / before 23:00 15 €", "old": "Admission 20 € / before 23:00 15 €"}, "fields": {}, "floor_changes": [], "floor_subtitle_changes": [], "floors_added": [], "floors_removed": [], "id": "2026-07-18", "kind": "modified", "slot_changes": [], "title": null, "url": "https://www.openground.club/en/schedule/2026-07-18"}], "run_at": "2026-06-01T08:13:54+00:00"}
